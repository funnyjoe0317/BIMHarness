# BIMHarness 환경변수 예시
# 이 파일을 .env로 복사하고 실제 값 채우기:
#   cp .env.example .env

# Anthropic API Key
# 발급: https://console.anthropic.com/ → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-여기에_실제_키_붙여넣기

# 사용 모델 (선택)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 온프레미스 로컬 LLM (Ollama) ─────────────────────────────
# 사내 보안망: IFC/룰을 클라우드로 안 보내고 로컬 모델로 컴파일.
#   1) ollama serve
#   2) ollama pull llama3.1
#   3) --ollama  또는  compile_rules(backend="ollama")
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
